{
  "name": "openclaw-manager-cli",
  "version": "0.1.0",
  "description": "CLI tool for managing OpenClaw installation and agents",
  "type": "module",
  "bin": {
    "openclaw-manager-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "dev:install": "tsx src/index.ts install",
    "dev:uninstall": "tsx src/index.ts uninstall",
    "dev:agent": "tsx src/index.ts agent",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
